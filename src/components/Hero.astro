---
---

<section id="top" class="relative overflow-hidden">
  <!-- decorative arc -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -right-40 -top-40 h-[34rem] w-[34rem] rounded-full bg-pine/10 blur-3xl"
  >
  </div>

  <div class="mx-auto max-w-6xl px-6 pt-20 pb-24 md:pt-28">
    <p class="reveal mb-6 inline-flex items-center gap-2 rounded-full border border-line bg-paper-deep px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-ink-soft">
      <span class="h-1.5 w-1.5 rounded-full bg-pine-soft"></span>
      Udělám to za vás
    </p>

    <h1 class="reveal display max-w-4xl text-balance text-4xl font-semibold leading-[1.05] tracking-tight sm:text-5xl md:text-7xl md:leading-[1.02]" style="animation-delay:.08s">
      Webové stránky a vše okolo -
      <span class="italic text-pine">bez technických starostí.</span>
    </h1>

    <p class="reveal mt-7 max-w-xl text-lg leading-relaxed text-ink-soft" style="animation-delay:.16s">
      Vy se staráte o své podnikání, já se postarám o vše ostatní: vytvořím vám
      stránky, zařídím vlastní adresu na internetu, zprovoz i pravidelnou údržbu.
      Nemusíte rozumět ničemu technickému.
    </p>

    <div class="reveal mt-10 flex flex-wrap items-center gap-4" style="animation-delay:.24s">
      <a
        href="#contact"
        class="group inline-flex items-center gap-2 rounded-full bg-ink px-7 py-3.5 text-base font-semibold text-paper transition-transform hover:-translate-y-0.5"
      >
        Chci nezávaznou konzultaci zdarma
        <svg class="transition-transform group-hover:translate-x-1" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <a href="#offers" class="inline-flex items-center gap-2 text-base font-semibold text-ink underline decoration-pine decoration-2 underline-offset-4 hover:text-pine">
        Zeptat se na cenu
      </a>
    </div>

    <!-- proof strip -->
    <div class="reveal mt-16 flex flex-wrap items-center gap-x-8 gap-y-3 border-t border-line pt-8 text-sm text-ink-soft" style="animation-delay:.32s">
      <span class="font-semibold text-ink">Pro koho:</span>
      <span>Malé firmy</span>
      <span class="text-line">•</span>
      <span>Živnostníci</span>
      <span class="text-line">•</span>
      <span>Tvůrci</span>
      <span class="text-line">•</span>
      <span>Místní služby</span>
      <span class="text-line">•</span>
      <span>Spolky a komunity</span>
    </div>
  </div>
</section>
