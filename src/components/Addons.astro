---
const addons = [
  { name: "Provoz Discord bota", desc: "Pomocník pro váš Discord, který běží nepřetržitě.", tag: "Komunita" },
  { name: "Server pro Minecraft", desc: "Vlastní herní svět pro vás a přátele - včetně záloh a stálého provozu.", tag: "Hraní" },
  { name: "Server pro TeamSpeak", desc: "Místo pro skupinové hovory s nízkým zpožděním.", tag: "Hlas" },
];
---

<section id="doplnky" class="border-t border-line bg-paper-deep/40">
  <div class="mx-auto max-w-6xl px-5 py-16 sm:px-6 md:py-20">
    <div class="grid gap-8 lg:grid-cols-[1fr_1.5fr] lg:items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-soft reveal">Doplňkové služby</p>
        <h2 class="display mt-3 text-2xl font-semibold tracking-tight md:text-3xl reveal">
          Doplňkové služby pro komunity a menší projekty
        </h2>
        <p class="mt-4 max-w-md text-sm leading-relaxed text-ink-soft reveal">
          Kromě webů umím zprovoznit a spravovat i servery pro vaši skupinu.
          Není to hlavní část mé práce, ale když to potřebujete, rád pomůžu.
        </p>
        <a href="#contact" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-pine transition-colors hover:text-pine-deep reveal">
          Domluvit se na doplňku
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        {addons.map((a) => (
          <div class="flex flex-col rounded-xl border border-line bg-paper p-5 transition-colors hover:border-pine-soft reveal">
            <span class="self-start rounded-full bg-mint px-3 py-1 text-[11px] font-semibold uppercase tracking-wider text-pine-deep">{a.tag}</span>
            <h3 class="display mt-4 text-lg font-semibold">{a.name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
