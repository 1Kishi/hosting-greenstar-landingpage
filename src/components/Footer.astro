---
const email = "jacobworkgreen@gmail.com";
const cols = [
  { h: "Menu", links: [["#sluzby", "Služby"], ["#cenik", "Ceník a péče"], ["#jak-to-probiha", "Jak to probíhá"], ["#ukazky", "Ukázky"], ["#proc", "Proč GreenStar"]] },
  { h: "Kde mě najdete", links: [["#", "Instagram"], ["#", "Facebook"], ["#", "LinkedIn"], ["#", "GitHub"]] },
];
---

<footer class="border-t border-line">
  <div class="mx-auto max-w-6xl px-5 pb-9 pt-16 sm:px-6 md:pt-20">
    <div class="mb-12 flex flex-wrap justify-between gap-10">
      {cols.map((c) => (
        <div>
          <h4 class="mb-4 font-mono text-[11px] uppercase tracking-[0.12em] text-ink-soft">{c.h}</h4>
          {c.links.map(([href, label]) => (
            <a href={href} class="mb-2.5 block text-base transition-colors hover:text-pine">{label}</a>
          ))}
        </div>
      ))}
      <div>
        <h4 class="mb-4 font-mono text-[11px] uppercase tracking-[0.12em] text-ink-soft">Kontakt</h4>
        <a href={`mailto:${email}`} class="mb-2.5 block text-base transition-colors hover:text-pine">{email}</a>
        <span class="font-mono text-[11px] uppercase tracking-wider text-ink-soft">Tábor, Česko</span>
      </div>
    </div>

    <div class="display select-none text-[clamp(48px,12vw,184px)] font-light leading-[0.85] tracking-tight opacity-95">GreenStar</div>

    <div class="mt-7 flex flex-wrap items-center justify-between gap-3.5 border-t border-line pt-6 font-mono text-[11px] uppercase tracking-[0.08em] text-ink-soft">
      <span>© 2026 GreenStar - weby, hosting a péče bez stresu</span>
      <span class="flex items-center gap-3">
        <a href="#contact" class="transition-colors hover:text-pine">Ochrana osobních údajů</a>
        <span aria-hidden="true">·</span>
        <span>Vytvořeno ručně · CZ &amp; SK</span>
      </span>
    </div>
  </div>
</footer>
