---
const services = [
  {
    n: "01",
    name: "Web na míru",
    desc: "Moderní, přehledné stránky postavené přímo pro vaše podnikání. Žádné šablony, které vypadají jako tisíc dalších - web, který si lidé zapamatují a který vám přivádí zákazníky. Vypadá dobře na mobilu, tabletu i počítači.",
  },
  {
    n: "02",
    name: "Doména a nastavení",
    desc: "Zařídím vlastní internetovou adresu (např. vasefirma.cz), propojení s Googlem a pomůžu s nastavením firemního e-mailu podle potřeby. Vše funguje a vy nemusíte řešit nic technického.",
  },
  {
    n: "03",
    name: "Hosting, zálohy a monitoring",
    desc: "Vaše stránky běží rychle a spolehlivě, s pravidelným zálohováním a hlídáním dostupnosti. I když zrovna spíte, web jede - a když se něco stane, řeším to za vás.",
  },
  {
    n: "04",
    name: "Péče a drobné úpravy",
    desc: "Úpravy textů a fotek, aktualizace a drobná vylepšení podle toho, jak se vaše podnikání mění. Stačí napsat a já se postarám - žádné čekání na agenturu.",
  },
];
---

<section id="sluzby" class="border-t border-line bg-paper-deep/40">
  <div class="mx-auto max-w-6xl px-5 py-20 sm:px-6 md:py-24">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <h2 class="display mt-3 max-w-[18ch] text-4xl font-semibold md:text-5xl reveal">
        Co pro vás <em class="not-italic text-pine">udělám</em> - od nápadu po provoz.
      </h2>
      <span class="font-mono text-xs uppercase tracking-[0.14em] text-ink-soft reveal">(02) - Služby</span>
    </div>

    <div class="mt-12 border-t border-line">
      {services.map((s) => (
        <div class="group grid grid-cols-1 items-center gap-2 border-b border-line py-7 transition-all duration-500 ease-[cubic-bezier(.16,1,.3,1)] hover:bg-paper md:grid-cols-[70px_1.1fr_1.7fr_auto] md:gap-8 md:py-8 md:hover:px-6 reveal">
          <div class="hidden font-mono text-sm text-pine md:block">{s.n}</div>
          <h3 class="display text-2xl font-semibold md:text-[28px]">{s.name}</h3>
          <p class="max-w-[56ch] text-[15px] leading-relaxed text-ink-soft">{s.desc}</p>
          <div class="hidden translate-x-[-8px] text-2xl text-pine opacity-0 transition-all duration-500 ease-[cubic-bezier(.16,1,.3,1)] group-hover:translate-x-0 group-hover:opacity-100 md:block" aria-hidden="true">→</div>
        </div>
      ))}
    </div>
  </div>
</section>
